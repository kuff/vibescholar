# Copy this file to .env and fill in your values.
# .env is loaded automatically when the server starts.

# Path to the local corpus data directory (default: ~/.vibescholar)
# VIBESCHOLAR_DATA_DIR=/path/to/data

# Semantic Scholar API key — apply at https://www.semanticscholar.org/product/api
# S2_API_KEY=your_key_here

# Email address for Unpaywall open-access lookups
# VIBESCHOLAR_EMAIL=you@example.com

# CORE API key — apply at https://core.ac.uk/services/api
# CORE_API_KEY=your_key_here
